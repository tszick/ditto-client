{
  "compilerOptions": {
    "target":            "ES2022",
    "module":            "NodeNext",
    "moduleResolution":  "NodeNext",
    "lib":               ["ES2022"],
    "types":             ["node"],
    "outDir":            "./dist",
    "rootDir":           "./src",
    "declaration":       true,
    "declarationMap":    true,
    "sourceMap":         true,
    "strict":            true,
    "noUncheckedIndexedAccess": true,
    "forceConsistentCasingInFileNames": true,
    "esModuleInterop":   false,
    "ignoreDeprecations": "6.0",
    "skipLibCheck":      true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
